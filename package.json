{
  "name": "findable",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --cwd apps/web run dev",
    "dev:api": "bun --cwd apps/api run dev",
    "build": "bun run --workspaces --if-present build",
    "typecheck": "bun run --workspaces typecheck"
  }
}
