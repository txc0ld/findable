# Core runtime
# Required for persistent accounts, scans, products, and issues.
DATABASE_URL=

# Required for queued background scan processing in production.
REDIS_URL=

# Auth + application URLs
FRONTEND_URL=https://getfindable.au
CORS_ORIGINS=https://getfindable.au
JWT_SECRET=
JWT_ISSUER=findable-api
COOKIE_DOMAIN=

# Required in production when the free scan form is public.
CLOUDFLARE_TURNSTILE_SECRET=
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=

# Frontend
VITE_API_URL=https://api.getfindable.au

# Billing
# Required when replacing the current plan-switch scaffold with real Stripe checkout/webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Store integrations
# Required when wiring real Shopify app install / admin API sync.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://api.getfindable.au/shopify
SHOPIFY_TOKEN_ENCRYPTION_KEY=
SHOPIFY_API_VERSION=2026-01

# Required when wiring real WooCommerce API sync.
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Optional next-phase services
# Use these only if you want richer crawl/extraction, email delivery, or product analytics.
FIRECRAWL_API_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Findable <no-reply@getfindable.au>
VITE_POSTHOG_KEY=
